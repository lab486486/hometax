---
import { mediaOrigin, site } from "../site.config";
import { getSiteSettings } from "../utils/site-settings";
import { getSiteIntegrationSnippets } from "../utils/site-integrations";
import AdSenseHead from "../components/AdSenseHead.astro";
import "../styles/site.css";
import "../styles/adsense.css";

interface Props {
  title?: string;
  description?: string;
  solidHeader?: boolean;
  noindex?: boolean;
  ogType?: string;
  ogImage?: string;
  articlePublishedTime?: string;
}

const settings = getSiteSettings();
const integrations = getSiteIntegrationSnippets();
const siteTitle = settings.title || site.title;

const {
  title = siteTitle,
  description = site.description,
  solidHeader = false,
  noindex = false,
  ogType = "website",
  ogImage,
  articlePublishedTime,
} = Astro.props;
const pageTitle = title === siteTitle ? title : `${title} · ${site.name}`;
const canonical = new URL(Astro.url.pathname, settings.site_url || site.baseUrl).href;
const r2Origin = mediaOrigin();
---

<!doctype html>
<html lang={site.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    {integrations.map((snippet) => <Fragment set:html={snippet} />)}
    <AdSenseHead />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {articlePublishedTime && <meta property="article:published_time" content={articlePublishedTime} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    {r2Origin && <link rel="preconnect" href={r2Origin} crossorigin />}
    {r2Origin && <link rel="dns-prefetch" href={r2Origin} />}
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#0c6e6b" />
  </head>
  <body class:list={[{ "solid-header": solidHeader }]}>
    <a class="skip-link" href="#main">본문으로 건너뛰기</a>
    <slot />
  </body>
</html>
