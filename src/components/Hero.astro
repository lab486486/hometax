---
import { media, site } from "../site.config";

const points = [
  {
    title: "4,900원으로 시작하는 워드프레스",
    text: "전자책 · 특강 신청으로 바로 시작하세요",
    href: site.wordpress,
  },
  {
    title: "카페24 포장이사(무료) 신청",
    text: "카페24 → 케미클라우드 이전 신청",
    href: site.cafe24,
  },
  {
    title: "클라우드웨이즈 포장이사(무료) 신청",
    text: "Cloudways → 케미클라우드 이전 신청",
    href: site.cloudways,
  },
];
---

<section class="hero" id="home">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="hero-kicker">유튜브 블로소득 · 워드프레스 멘토링</p>
      <h1>커피 한잔 값으로 구축하는 <em>나만의 워드프레스</em></h1>
      <p class="hero-lead">
        비싼 VPS 대신 케미클라우드로 시작하고, 애드센스 승인까지 시행착오 없이 가는 핵심 로드맵을 공유합니다.
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={site.wordpress}>케미클라우드 시작</a>
        <a class="btn btn-secondary" href={site.lecture}>특강 영상 보기</a>
      </div>
      <div class="hero-points">
        {
          points.map((p) => (
            <a class="hero-point" href={p.href}>
              <strong>{p.title}</strong>
              <span>{p.text}</span>
            </a>
          ))
        }
      </div>
    </div>

    <div class="hero-visual">
      <img
        src={media("images/about.webp")}
        alt="블로소득 워드프레스 가이드 일러스트"
        width="500"
        height="373"
        fetchpriority="high"
        decoding="async"
      />
      <div class="hero-badge">
        <a
          class="hero-badge-link"
          href="https://youtube.com/@블로그"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="yt-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" width="29" height="22" focusable="false">
              <rect x="1" y="3" width="22" height="18" rx="4" fill="#ff0000"></rect>
              <path d="M10 8.2v7.6L16.5 12 10 8.2z" fill="#fff"></path>
            </svg>
          </span>
          <span>블로소득</span>
        </a>
        <small>블로그스팟+워드프레스 전문채널</small>
      </div>
    </div>
  </div>
</section>
