---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../site.config";

interface Props {
  title: string;
  description: string;
  formType: "wordpress" | "cafe24" | "cloudways";
  eyebrow: string;
}

const { title, description, formType, eyebrow } = Astro.props;
const sent = Astro.url.searchParams.get("sent") === "1";
const errored = Astro.url.searchParams.get("error") === "1";
---

<Layout title={title} description={description} solidHeader>
  <Header />
  <main id="main" class="form-page">
    <section class="section">
      <div class="container form-wrap">
        <p class="section-eyebrow">{eyebrow}</p>
        <h1>{title}</h1>
        <slot name="intro" />

        <aside class="form-affiliate" role="note">
          <p>
            아래 <strong class="form-affiliate-em">추천 링크로 가입</strong>하신 뒤, 발급된
            <strong>인보이스(invoice) 번호</strong>를 신청서에 남겨 주세요.
            검색으로 직접 가입하시면 혜택·안내 대상에서 제외될 수 있습니다.
          </p>
          <a class="btn btn-primary" href={site.chemicloud} rel="noopener noreferrer">
            케미클라우드 추천 링크로 가입하기
          </a>
        </aside>

        {
          sent && (
            <p class="form-banner ok" role="status">
              신청이 접수되었습니다. 확인 후 안내 메일을 보내드릴게요.
            </p>
          )
        }
        {
          errored && (
            <p class="form-banner err" role="alert">
              전송에 실패했습니다. 잠시 후 다시 시도해 주세요.
            </p>
          )
        }

        <form class="app-form" method="POST" action="/api/forms">
          <input type="hidden" name="formType" value={formType} />
          <input type="text" name="website" class="hp" tabindex="-1" autocomplete="off" aria-hidden="true" />
          <slot />
          <button class="btn btn-primary" type="submit">신청서 제출</button>
        </form>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
