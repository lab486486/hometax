---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HomeIcon from "../components/HomeIcon.astro";
import AdSlot from "../components/AdSlot.astro";
import PostCardImage from "../components/PostCardImage.astro";
import { getBlogPosts, getGunmartPosts, postUrl, formatDate } from "../utils/posts";
import { popularCalculators } from "../data/calculators";
import { getAdsenseConfig, getHomeAdCode, hasHomeAd } from "../utils/adsense";
import { site } from "../site.config";
import "../styles/calculators.css";

const taxPosts = await getBlogPosts();
const gunPosts = await getGunmartPosts();
const calcs = popularCalculators().slice(0, 4);
const featured = taxPosts.filter((p) => p.data.cover_image).slice(0, 6);
const latestTax = taxPosts.slice(0, 6);
const adsense = getAdsenseConfig();
const showHomeAd = hasHomeAd(adsense);
const homeAdCode = getHomeAdCode(adsense);

const topics = [
  { label: "종합소득세", href: "/category/%ED%99%88%ED%83%9D%EC%8A%A4/" },
  { label: "연말정산", href: "/category/%EC%97%B0%EB%A7%90%EC%A0%95%EC%82%B0/" },
  { label: "근로·지원금", href: "/category/%ED%99%88%ED%83%9D%EC%8A%A4/" },
  { label: "부동산·명의", href: "/category/%EB%AA%85%EC%9D%98%EB%B3%80%EA%B2%BD/" },
  { label: "서류 발급", href: "/category/%ED%99%88%ED%83%9D%EC%8A%A4/" },
  { label: "군마트", href: "/category/%EA%B5%B0%EB%A7%88%ED%8A%B8/" },
];
---

<Layout inverseHeader>
  <Header />
  <main id="main">
    <section class="home-hero-band" id="home">
      <div class="container">
        <p class="hero-kicker">세금 계산기 & 실무 가이드</p>
        <div class="home-hero-layout">
          <div class="home-hero-copy">
            <h1>{site.name}</h1>
            <p class="hero-lead">
              연봉 실수령액부터 종합소득세·취득세까지. 자주 쓰는 계산기와 홈택스 실무 글을 한곳에서 확인하세요.
            </p>
            <div class="hero-actions home-hero-actions">
              <a class="btn btn-primary" href="/calculator/salary/">연봉 실수령액 계산</a>
              <a class="btn btn-secondary" href="#calculators">인기 계산기</a>
            </div>
          </div>

          <aside class="home-hero-topics" aria-label="주제별 가이드">
            <div class="topic-grid topic-grid-home topic-grid-hero">
              {
                topics.map((t) => (
                  <a class="topic-card topic-card-title topic-card-hero" href={t.href}>
                    <strong>{t.label}</strong>
                  </a>
                ))
              }
            </div>
          </aside>
        </div>
      </div>
    </section>

    {
      showHomeAd && (
        <section class="home-ad-band" aria-label="광고">
          <div class="container">
            <AdSlot html={homeAdCode} class="ad-slot-home" />
          </div>
        </section>
      )
    }

    <section class="section home-section-tight" id="calculators">
      <div class="container">
        <div class="section-head">
          <p class="section-eyebrow">Popular</p>
          <h2>인기 계산기</h2>
          <p>가장 많이 찾는 세금·생활 계산기만 추렸습니다.</p>
        </div>
        <div class="calc-grid calc-grid-home">
          {
            calcs.map((c, i) => (
              <a class="calc-tile" href={`/calculator/${c.slug}/`}>
                <span class="calc-tile-icon" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
                <strong>{c.title}</strong>
                <span>{c.short}</span>
              </a>
            ))
          }
        </div>
        <p class="home-more" style="margin-top:1.25rem;text-align:right;">
          <a class="section-link" href="/calculator/">계산기 전체 보기 →</a>
        </p>
      </div>
    </section>

    <section class="section home-section-tight home-topics-mobile" style="padding-top:0;">
      <div class="container">
        <div class="section-head">
          <p class="section-eyebrow">Topics</p>
          <h2>주제별 가이드</h2>
          <p>궁금한 세금을 골라 바로 들어가 보세요.</p>
        </div>
        <div class="topic-grid topic-grid-home">
          {
            topics.map((t) => (
              <a class="topic-card topic-card-title" href={t.href}>
                <strong>{t.label}</strong>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section" id="featured">
      <div class="container">
        <div class="section-head">
          <p class="section-eyebrow">Guides</p>
          <h2>세금 실무 가이드</h2>
          <p>홈택스·신고·서류 발급을 단계별로 정리한 글입니다.</p>
        </div>
        <ul class="post-grid">
          {
            featured.map((post) => (
              <li>
                <a class="post-card" href={postUrl(post)}>
                  <div class="post-card-media">
                    {post.data.cover_image ? (
                      <PostCardImage src={post.data.cover_image} />
                    ) : (
                      <div class="post-card-fallback" aria-hidden="true">
                        <HomeIcon size={40} />
                      </div>
                    )}
                  </div>
                  <div class="post-card-body">
                    <span class="post-card-tag">{post.data.tags[0] || "홈택스"}</span>
                    <h2>{post.data.title}</h2>
                    <p class="post-card-excerpt">{post.data.description}</p>
                    <div class="post-card-author">
                      <span class="post-card-avatar" aria-hidden="true">
                        <HomeIcon size={18} />
                      </span>
                      <div>
                        <strong>{site.name}</strong>
                        <time datetime={post.data.date.toISOString().slice(0, 10)}>
                          {formatDate(post.data.date)}
                        </time>
                      </div>
                    </div>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="section home-section-tight">
      <div class="container home-lists">
        <div>
          <div class="section-head">
            <p class="section-eyebrow">Latest</p>
            <h2>최신 글</h2>
          </div>
          <ul class="home-link-list">
            {
              latestTax.map((post) => (
                <li>
                  <a class="home-link-item" href={postUrl(post)}>
                    <span class="home-link-meta">
                      <span class="home-link-tag">{post.data.tags[0] || "홈택스"}</span>
                      <time datetime={post.data.date.toISOString().slice(0, 10)}>
                        {formatDate(post.data.date)}
                      </time>
                    </span>
                    <span class="home-link-title home-link-title-ellipsis">{post.data.title}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        {
          gunPosts.length > 0 && (
            <div>
              <div class="section-head">
                <p class="section-eyebrow">참고 자산</p>
                <h2>군마트 정보</h2>
                <p>검색 유입용으로 별도 관리하는 페이지입니다.</p>
              </div>
              <ul class="home-link-list">
                {gunPosts.slice(0, 4).map((post) => (
                  <li>
                    <a class="home-link-item home-link-item-title" href={postUrl(post)}>
                      <span class="home-link-title home-link-title-ellipsis">{post.data.title}</span>
                    </a>
                  </li>
                ))}
              </ul>
              <p class="home-more">
                <a class="section-link" href="/category/%EA%B5%B0%EB%A7%88%ED%8A%B8/">군마트 목록 →</a>
              </p>
            </div>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>
