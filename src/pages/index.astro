---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getBlogPosts, getGunmartPosts, postUrl, formatDate } from "../utils/posts";
import { popularCalculators } from "../data/calculators";
import { site } from "../site.config";
import "../styles/calculators.css";

const taxPosts = await getBlogPosts();
const gunPosts = await getGunmartPosts();
const calcs = popularCalculators().slice(0, 4);
const featured = taxPosts.filter((p) => p.data.cover_image).slice(0, 6);
const latestTax = taxPosts.slice(0, 6);

const topics = [
  { label: "종합소득세", href: "/category/%ED%99%88%ED%83%9D%EC%8A%A4/" },
  { label: "연말정산", href: "/category/%EC%97%B0%EB%A7%90%EC%A0%95%EC%82%B0/" },
  { label: "근로·지원금", href: "/category/%ED%99%88%ED%83%9D%EC%8A%A4/" },
  { label: "군마트", href: "/category/%EA%B5%B0%EB%A7%88%ED%8A%B8/" },
];
---

<Layout inverseHeader>
  <Header />
  <main id="main">
    <section class="home-hero-band" id="home">
      <div class="container">
        <p class="hero-kicker">세금 계산기 & 실무 가이드</p>
        <h1>{site.name}</h1>
        <p class="hero-lead">
          연봉 실수령액부터 종합소득세·취득세까지. 자주 쓰는 계산기와 홈택스 실무 글을 한곳에서 확인하세요.
        </p>
        <div class="hero-actions home-hero-actions">
          <a class="btn btn-primary" href="/calculator/salary/">연봉 실수령액 계산</a>
          <a class="btn btn-secondary" href="#calculators">인기 계산기</a>
        </div>
        <p class="home-disclaimer">
          국세청 홈택스와 무관한 독립 정보 사이트입니다.<br />
          계산 결과는 참고용입니다.
        </p>
      </div>
    </section>

    <section class="section home-section-tight" id="calculators">
      <div class="container">
        <div class="section-head">
          <p class="section-eyebrow">Popular</p>
          <h2>인기 계산기</h2>
          <p>가장 많이 찾는 세금·생활 계산기만 추렸습니다.</p>
        </div>
        <div class="calc-grid calc-grid-home">
          {
            calcs.map((c, i) => (
              <a class="calc-tile" href={`/calculator/${c.slug}/`}>
                <span class="calc-tile-icon" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
                <strong>{c.title}</strong>
                <span>{c.short}</span>
              </a>
            ))
          }
        </div>
        <p class="home-more" style="margin-top:1.25rem;text-align:right;">
          <a class="section-link" href="/calculator/">계산기 전체 보기 →</a>
        </p>
      </div>
    </section>

    <section class="section home-section-tight" style="padding-top:0;">
      <div class="container">
        <div class="section-head">
          <p class="section-eyebrow">Topics</p>
          <h2>주제별 가이드</h2>
          <p>궁금한 세금을 골라 바로 들어가 보세요.</p>
        </div>
        <div class="topic-grid topic-grid-home">
          {
            topics.map((t) => (
              <a class="topic-card topic-card-title" href={t.href}>
                <strong>{t.label}</strong>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section" id="featured">
      <div class="container">
        <div class="section-head">
          <p class="section-eyebrow">Guides</p>
          <h2>세금 실무 가이드</h2>
          <p>홈택스·신고·서류 발급을 단계별로 정리한 글입니다.</p>
        </div>
        <ul class="post-grid">
          {
            featured.map((post) => (
              <li>
                <a class="post-card" href={postUrl(post)}>
                  <div class="post-card-media">
                    {post.data.cover_image ? (
                      <img src={post.data.cover_image} alt="" width="640" height="360" loading="lazy" />
                    ) : (
                      <div class="post-card-fallback" aria-hidden="true">홈</div>
                    )}
                  </div>
                  <div class="post-card-body">
                    <span class="post-card-tag">{post.data.tags[0] || "홈택스"}</span>
                    <h2>{post.data.title}</h2>
                    <p class="post-card-excerpt">{post.data.description}</p>
                    <div class="post-card-author">
                      <span class="post-card-avatar" aria-hidden="true">홈</span>
                      <div>
                        <strong>{site.name}</strong>
                        <time datetime={post.data.date.toISOString().slice(0, 10)}>
                          {formatDate(post.data.date)}
                        </time>
                      </div>
                    </div>
                  </div>
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class="section home-section-tight">
      <div class="container" style="display:grid;gap:2rem;">
        <div>
          <div class="section-head">
            <p class="section-eyebrow">Latest</p>
            <h2>최신 글</h2>
          </div>
          <ul class="home-feed">
            {
              latestTax.map((post) => (
                <li>
                  <a href={postUrl(post)} style="display:grid;grid-template-columns:auto 1fr auto;gap:.75rem;align-items:baseline;padding:.85rem 0;border-bottom:1px solid var(--line);">
                    <span class="home-feed-tag" style="font-size:.78rem;font-weight:700;color:var(--brand-dark);background:var(--brand-soft);padding:.2rem .5rem;border-radius:.4rem;">
                      {post.data.tags[0] || "홈택스"}
                    </span>
                    <span style="font-weight:600;">{post.data.title}</span>
                    <time datetime={post.data.date.toISOString().slice(0, 10)} style="color:var(--muted);font-size:.85rem;white-space:nowrap;">
                      {formatDate(post.data.date)}
                    </time>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        {
          gunPosts.length > 0 && (
            <div>
              <div class="section-head">
                <p class="section-eyebrow">참고 자산</p>
                <h2>군마트 정보</h2>
                <p>검색 유입용으로 별도 관리하는 페이지입니다.</p>
              </div>
              <ul style="list-style:none;margin:0;padding:0;display:grid;gap:.35rem;">
                {gunPosts.slice(0, 4).map((post) => (
                  <li>
                    <a href={postUrl(post)} style="display:block;padding:.85rem 0;border-bottom:1px solid var(--line);font-weight:600;">
                      {post.data.title}
                    </a>
                  </li>
                ))}
              </ul>
              <p style="margin-top:1rem;text-align:right;">
                <a class="section-link" href="/category/%EA%B5%B0%EB%A7%88%ED%8A%B8/">군마트 목록 →</a>
              </p>
            </div>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</Layout>
