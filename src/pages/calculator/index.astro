---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { calculators } from "../../data/calculators";
import "../../styles/calculators.css";
---

<Layout
  title="세금 계산기"
  description="연봉 실수령액, 종합소득세, 취득세, 증여세 등 인기 세금 계산기"
  solidHeader
>
  <Header />
  <main id="main" class="calc-page">
    <div class="container">
      <header class="calc-hero">
        <p class="section-eyebrow">Calculators</p>
        <h1>인기 세금 계산기</h1>
        <p>가장 많이 찾는 계산기만 모았습니다. 결과는 참고용이며, 정확한 신고는 홈택스·세무사 상담을 권장합니다.</p>
      </header>
      <div class="calc-grid">
        {
          calculators.map((c, i) => (
            <a class="calc-tile" href={`/calculator/${c.slug}/`}>
              <span class="calc-tile-icon" aria-hidden="true">{String(i + 1).padStart(2, "0")}</span>
              <strong>{c.title}</strong>
              <span>{c.short}</span>
            </a>
          ))
        }
      </div>
    </div>
  </main>
  <Footer />
</Layout>
